# ============================================================
# HRMS Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# ============================================================

# Server
PORT=4000
NODE_ENV=production

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (must match Supabase JWT secret — Settings → API → JWT Secret)
JWT_SECRET=your-jwt-secret-here

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=https://your-app.vercel.app

# Firebase Admin SDK (paste the entire service account JSON as a single-line string)
# Leave empty or "none" if you don't use push notifications
FIREBASE_SERVICE_ACCOUNT_JSON=
